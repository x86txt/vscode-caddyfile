{
	"name": "caddyfile-syntax",
	"displayName": "Caddyfile Syntax by Secunit",
	"description": "Rich Caddyfile Syntax Highlighting for Visual Studio Code",
	"version": "0.4.2",
	"license": "MIT",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"main": "packages/client/dist/index.js",
	"icon": "media/caddy-logo.png",
	"categories": [
		"Programming Languages",
		"Linters",
		"Formatters"
	],
	"publisher": "secunit",
	"author": {
		"name": "secunit"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/x86txt/vscode-caddyfile"
	},
	"bugs": {
		"url": "https://github.com/x86txt/vscode-caddyfile/issues"
	},
	"engines": {
		"node": ">=24.14.1",
		"vscode": ">=1.75.0"
	},
	"scripts": {
		"vscode:prepublish": "turbo run build",
		"package": "mkdir -p dist && vsce package --no-dependencies --no-yarn --out dist/caddyfile-syntax.vsix",
		"build": "turbo run build",
		"dev": "turbo run dev --no-cache --parallel --continue",
		"lint": "turbo run lint",
		"clean": "turbo run clean && rimraf node_modules/.cache",
		"install:deps": "node scripts/install-deps.mjs"
	},
	"devDependencies": {
		"@vscode/vsce": "^2.32.0",
		"prettier": "^3.8.2",
		"rimraf": "^6.1.3",
		"turbo": "^1.13.4",
		"typescript": "^5.9.3"
	},
	"extensionDependencies": [],
	"activationEvents": [
		"workspaceContains:**/Caddyfile",
		"workspaceContains:**/Caddyfile*",
		"workspaceContains:**/caddyfile",
		"workspaceContains:**/caddyfile*",
		"workspaceContains:**/*.Caddyfile",
		"workspaceContains:**/*.caddyfile",
		"workspaceContains:**/*.caddy",
		"workspaceContains:**/*.Caddy"
	],
	"contributes": {
		"languages": [
			{
				"id": "caddyfile",
				"configuration": "./language-configuration.json",
				"aliases": [
					"Caddyfile",
					"Caddy",
					"caddyfile",
					"caddy"
				],
				"filenames": [
					"Caddyfile",
					"caddyfile"
				],
				"filenamePatterns": [
					"Caddyfile*",
					"caddyfile*"
				],
				"extensions": [
					".caddy",
					".Caddy",
					".caddyfile",
					".Caddyfile"
				]
			},
			{
				"id": "caddyfile-test",
				"configuration": "./language-configuration.json",
				"aliases": [
					"Caddyfile-test"
				],
				"extensions": [
					".Caddyfiletest",
					".caddyfiletest"
				]
			}
		],
		"grammars": [
			{
				"language": "caddyfile",
				"scopeName": "source.Caddyfile",
				"path": "./syntaxes/caddyfile.tmLanguage.json"
			},
			{
				"language": "caddyfile-test",
				"scopeName": "source.Caddyfile-test",
				"path": "./syntaxes/caddyfile-test.tmLanguage.json"
			},
			{
				"scopeName": "source.markdown.caddy.codeblock",
				"path": "./syntaxes/caddy-markdown.tmLanguage.json",
				"injectTo": [
					"text.html.markdown"
				],
				"embeddedLanguages": {
					"meta.embedded.block.caddy": "caddyfile"
				}
			}
		],
		"configurationDefaults": {
			"[caddyfile]": {
				"editor.insertSpaces": false,
				"editor.formatOnSave": true
			}
		},
		"configuration": {
			"title": "Caddyfile",
			"properties": {
				"caddyfile.executable": {
					"type": "string",
					"default": "",
					"description": "Location of the `caddy` executable to use for code formatting and linting."
				}
			}
		}
	},
	"pnpm": {
		"overrides": {
			"esbuild@<=0.24.2": ">=0.25.0"
		}
	}
}
